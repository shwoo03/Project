# ============================================
# AI News Digest Bot - Environment Variables
# ============================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-chat-id-or-channel-id

# --- Telegram User Auth (Telethon - for channel crawling) ---
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your-api-hash-from-my-telegram-org
TELEGRAM_PHONE=+821012345678

# --- X (Twitter) Web Auth (Playwright) ---
X_USERNAME=your_x_username
X_PASSWORD=your_x_password
X_EMAIL=your_email_for_challenge

# --- OpenAI / Codex ---
OPENAI_API_KEY=your-openai-api-key
CODEX_MODEL=o4-mini

# --- Storage ---
DB_PATH=data/news.db

# --- Schedule (KST, 24h format) ---
SCHEDULE_HOURS=7,12,20
TIMEZONE=Asia/Seoul

# --- Misc ---
LOG_LEVEL=INFO
MAX_ITEMS_PER_DIGEST=30
SUMMARY_LANGUAGE=ko
